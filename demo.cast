[5.753364, "o", "project: k8s-demo\r\n\r\ncluster:\r\n  context: kubernetes-admin@kubernetes\r\n  namespace: k8s-demo\r\n\r\nmanifests:\r\n  - /opt/k8s-deploy-community/k8s-demo/manifests/01-namespace.yaml\r\n  - /opt/k8s-deploy-community/k8s-demo/manifests/02-pod.yaml\r\n\r\npipeline:\r\n  health_check_timeout: 60s\r\n  health_check_poll: 3s\r\n  rollback_on_failure: true\r\n"]
