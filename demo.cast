[0.006018, "o", "\u001b[0;36m             Go-K8SDeploy - Native Kubernetes Orcherstration Engine      \u001b[0m\r\n\u001b[0;34m=========================================================================\u001b[0m\r\nDeveloped by: \u001b[0;33mYour Net Tec\u001b[0m | License: \u001b[0;32mAGPL\u001b[0m\r\nStarting demonstration playback (Real GitOps Drift & Reconcile)...\r\n\r\n"]
